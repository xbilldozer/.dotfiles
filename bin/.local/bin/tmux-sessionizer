#!/usr/bin/env zsh

if [[ $# -eq 1 ]]; then
    selected=$1
elif [[ $# -eq 2 ]]; then
    selected=$1
    selected_name=$2
else
	fzf_result=$(find $PROJECTS/* -type d -o -type l -maxdepth 0 | fzf --print-query --header="New session")

  if [[ $? -eq 130 ]]; then
    echo "Exit workflow"
    exit 0
  fi

  results=("${(f)fzf_result}")
  query="${results[1]}"
  selected="${results[2]}"

  if [[ -z "$selected" ]] && [[ -n "$query" ]]; then
    selected=$query
  fi
fi

if [[ -z $selected ]]; then
    exit 0
fi

if [[ -z $selected_name ]]; then
  selected_name="$(basename "$selected" | tr . _)"
fi

tmux_running="$(pgrep tmux)"

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    exit 0
fi

if ! tmux has-session -t=$selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

tmux switch-client -t $selected_name
